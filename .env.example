# Domain & SSL
DOMAIN=asutport.ru
CERTBOT_EMAIL=erman.ai@yandex.ru

# App
ENVIRONMENT=development
LOG_LEVEL=info
VERSION=0.1.0
SERVER_PORT=8080
BUILD_ID=dev

# PostgreSQL
POSTGRES_DB=asutport
POSTGRES_USER=asutport
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# WordPress MySQL
WP_DB_NAME=asutport_wp
WP_DB_USER=asutport_wp
WP_DB_PASSWORD=change_me_wp
WP_DB_ROOT_PASSWORD=change_me_wp_root

# Auth
JWT_SECRET=change_me_jwt_secret_min_16_chars
API_KEY_SALT=change_me_api_key_salt

# S3 (dev: MinIO; prod: Beget S3)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=asutport
S3_ACCESS_KEY=asutport_minio
S3_SECRET_KEY=change_me_minio_secret
S3_USE_PATH_STYLE=true

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL_QUALIFY=google/gemini-2.5-flash
OPENROUTER_MODEL_ANSWER=anthropic/claude-sonnet-4
OPENROUTER_MODEL_VISION=google/gemini-2.5-pro
OPENROUTER_MODEL_KB=anthropic/claude-sonnet-4
OPENROUTER_MODEL_EMBED=openai/text-embedding-3-large

# Frontend
NEXT_PUBLIC_APP_NAME=ASUTPORT
NEXT_PUBLIC_API_URL=/api/v1
