│   └── src/app/
│       ├── (public)/kb/          # публичная база знаний: SSR/ISR, SEO, виджет агента
│       ├── (dashboard)/dashboard/  # кабинет клиента
│       ├── (vendor)/vendor/        # кабинет производителя
│       ├── (admin)/admin/          # суперадминка
